# =============================================================================
# PodDeck Configuration
# Copy this file to .env and fill in the required values.
# =============================================================================

# --- Database ----------------------------------------------------------------
DB_USERNAME=poddeck
DB_PASSWORD=              # REQUIRED: set a strong password

# --- Authentication ----------------------------------------------------------
# Generate with: openssl rand -hex 16
AUTH_KEY=                 # REQUIRED: 32-character secret for JWT signing
REFRESH_KEY=              # REQUIRED: 32-character secret for JWT refresh

# --- gRPC (Agent Connection) -------------------------------------------------
# The hostname/IP that agents in remote clusters will use to reach this server.
# This MUST be reachable from your Kubernetes clusters.
GRPC_HOST=localhost
GRPC_PORT=10101

# --- Panel -------------------------------------------------------------------
PANEL_PORT=80

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins for the panel.
ALLOWED_ORIGINS=http://localhost
